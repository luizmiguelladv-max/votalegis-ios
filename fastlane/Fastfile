default_platform(:ios)

require "tmpdir"

BUNDLE_ID = "br.com.votalegis"
PROFILE   = "match AppStore #{BUNDLE_ID}"

platform :ios do
  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"],
      is_key_content_base64: false,
      in_house: false
    )
  end

  lane :beta do
    # GOTCHA #3 — CRÍTICO: destrava o keychain do runner. Sem isso o codesign
    # TRAVA silenciosamente no passo "Embed Pods Frameworks" até o timeout.
    setup_ci

    api_key = asc_api_key

    increment_build_number(
      xcodeproj: "ios/App/App.xcodeproj",
      build_number: ENV["BUILD_NUMBER"]
    )

    # Baixa/gera os certificados + provisioning do repo de certs (match).
    match(
      type: "appstore",
      api_key: api_key,
      readonly: false # 1º build cria os certs e sobe pro repo; depois reusa.
    )

    # GOTCHA #4 — CRÍTICO: o projeto do Capacitor vem SEM assinatura. Força
    # assinatura MANUAL com o time + o profile do match, senão o build sai sem
    # assinar e o upload falha.
    update_code_signing_settings(
      path: "ios/App/App.xcodeproj",
      use_automatic_signing: false,
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      bundle_identifier: BUNDLE_ID,
      profile_name: PROFILE
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: { BUNDLE_ID => PROFILE }
      },
      output_directory: "build",
      output_name: "App.ipa",
      clean: true
    )

    # Confirma o conteúdo do artefato que será enviado, não apenas os arquivos
    # do checkout. Assim o CI falha se a camada iOS ficar fora do IPA ou se o
    # nome visível do aplicativo regredir.
    Dir.mktmpdir("votalegis-ipa-") do |check_dir|
      unless system("unzip", "-q", "build/App.ipa", "-d", check_dir)
        UI.user_error!("Não foi possível inspecionar o IPA gerado")
      end

      app_dir = Dir[File.join(check_dir, "Payload", "*.app")].first
      UI.user_error!("Bundle .app não encontrado no IPA") unless app_dir

      bundled_script = File.join(app_dir, "public", "votalegis-ios.js")
      UI.user_error!("Camada responsiva iOS ausente do IPA") unless File.file?(bundled_script)
      unless File.binread(bundled_script) == File.binread("native/votalegis-ios.js")
        UI.user_error!("Camada responsiva no IPA diverge do arquivo versionado")
      end

      display_name = `/usr/libexec/PlistBuddy -c "Print:CFBundleDisplayName" "#{File.join(app_dir, "Info.plist")}"`.strip
      UI.user_error!("Nome visível incorreto no IPA: #{display_name}") unless display_name == "VotaLegis"
      UI.success!("IPA contém a UI iOS v2 e exibe o nome VotaLegis")
    end

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
